{
  "name": "@spondylatlas/agent-sdk",
  "version": "1.0.1",
  "description": "TypeScript SDK for the SpondylAtlas research platform API",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
  },
  "license": "MIT",
  "keywords": [
    "spondylitis",
    "axspa",
    "ankylosing-spondylitis",
    "research",
    "medical",
    "agent",
    "sdk",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MoritzGan/spondylatlas.git",
    "directory": "packages/agent-sdk"
  },
  "homepage": "https://spondylatlas.web.app",
  "bugs": {
    "url": "https://github.com/MoritzGan/spondylatlas/issues"
  }
}
