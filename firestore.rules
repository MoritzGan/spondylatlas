rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function matchesAuthOrNull(userId) {
      return userId == null || (isSignedIn() && request.auth.uid == userId);
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isModerator() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "moderator"];
    }

    function notChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /legal_document_versions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_legal_acceptances/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.version is string;
      allow delete: if false;
    }

    match /health_data_consents/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.version is string &&
        request.resource.data.granted is bool;
      allow delete: if false;
    }

    match /account_requests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.type in ["export", "delete"] &&
        request.resource.data.status == "requested";
      allow update, delete: if isAdmin();
    }

    match /audit_events/{eventId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.eventType is string;
      allow update, delete: if false;
    }

    match /content_reports/{reportId} {
      allow read: if isModerator() ||
        (isSignedIn() && resource.data.reporterUserId == request.auth.uid);
      allow create: if matchesAuthOrNull(request.resource.data.reporterUserId) &&
        request.resource.data.contentUrl is string &&
        request.resource.data.contentUrl.size() <= 500 &&
        request.resource.data.contentType is string &&
        request.resource.data.contentType.size() <= 100 &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() <= 100 &&
        request.resource.data.details is string &&
        request.resource.data.details.size() <= 4000;
      allow update, delete: if isModerator();
    }

    match /papers/{paperId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trials/{trialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /forum_posts/{postId} {
      allow read: if isSignedIn() &&
        (resource.data.status == "published" ||
         isOwner(resource.data.authorId) ||
         isModerator());

      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.status == "pending_moderation" &&
        request.resource.data.content.size() <= 10000 &&
        request.resource.data.title.size() <= 300;

      allow update: if (
          isOwner(resource.data.authorId) &&
          notChanging("status") &&
          notChanging("authorId")
        ) || isModerator();

      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /forum_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.content.size() <= 3000;
      allow update: if isOwner(resource.data.authorId) &&
        notChanging("authorId") &&
        notChanging("postId");
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isSignedIn() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }


    // ── /agent_events ─────────────────────────────────────────────────────────
    match /agent_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── /agent_runs ───────────────────────────────────────────────────────────
    match /agent_runs/{runId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
