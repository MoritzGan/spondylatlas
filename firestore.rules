rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function matchesAuthOrNull(userId) {
      return userId == null || (isSignedIn() && request.auth.uid == userId);
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function consentDocPath() {
      return /databases/$(database)/documents/health_data_consents/$(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(userDocPath()) &&
        get(userDocPath()).data.role == "admin";
    }

    function isModerator() {
      return isSignedIn() &&
        exists(userDocPath()) &&
        get(userDocPath()).data.role in ["admin", "moderator"];
    }

    function notChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    function changedKeysAreOnly(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    function hasVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function hasActiveHealthConsent() {
      return isSignedIn() &&
        exists(consentDocPath()) &&
        get(consentDocPath()).data.granted == true;
    }

    function isCommunityMember() {
      return hasVerifiedEmail() && hasActiveHealthConsent();
    }

    function forumPostPath(postId) {
      return /databases/$(database)/documents/forum_posts/$(postId);
    }

    function forumPostExists(postId) {
      return exists(forumPostPath(postId));
    }

    function canReadForumPost(postId) {
      return forumPostExists(postId) &&
        (
          get(forumPostPath(postId)).data.status == "published" ||
          get(forumPostPath(postId)).data.authorId == request.auth.uid ||
          isModerator()
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          "displayName", "email", "lang", "role", "ageConfirmed", "legalVersion", "createdAt", "updatedAt"
        ]) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 200 &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.lang in ["de", "en"] &&
        request.resource.data.role == "user" &&
        request.resource.data.ageConfirmed == true &&
        request.resource.data.legalVersion is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() || (
        isOwner(userId) &&
        changedKeysAreOnly(["displayName", "lang", "updatedAt"]) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 200 &&
        request.resource.data.lang in ["de", "en"] &&
        notChanging("role") &&
        notChanging("email") &&
        notChanging("ageConfirmed") &&
        notChanging("legalVersion") &&
        notChanging("createdAt")
      );
      allow delete: if isAdmin();
    }

    match /legal_document_versions/{docId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.type is string &&
        request.resource.data.version is string &&
        request.resource.data.content is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.type is string &&
        request.resource.data.version is string &&
        request.resource.data.content is string;
      allow delete: if isAdmin();
    }

    match /user_legal_acceptances/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.version is string;
      allow delete: if false;
    }

    match /health_data_consents/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.version is string &&
        request.resource.data.granted is bool &&
        (
          !("scope" in request.resource.data) ||
          request.resource.data.scope == "community_forum"
        );
      allow delete: if false;
    }

    match /account_requests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.type in ["export", "delete"] &&
        request.resource.data.status == "requested" &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update, delete: if isAdmin();
    }

    match /audit_events/{eventId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.eventType is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update, delete: if false;
    }

    match /content_reports/{reportId} {
      allow read: if isModerator() ||
        (isSignedIn() && resource.data.reporterUserId == request.auth.uid);
      allow create: if false;
      allow update, delete: if isModerator();
    }

    match /papers/{paperId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.abstract is string &&
        request.resource.data.source is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0;
      allow delete: if isAdmin();
    }

    match /trials/{trialId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.nctId is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.title is string;
      allow delete: if isAdmin();
    }

    match /forum_posts/{postId} {
      allow read: if isCommunityMember() &&
        (
          resource.data.status == "published" ||
          isOwner(resource.data.authorId) ||
          isModerator()
        );

      allow create: if isCommunityMember() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.authorName is string &&
        request.resource.data.authorName.size() <= 200 &&
        request.resource.data.category in [
          "general",
          "symptoms",
          "treatment",
          "exercise",
          "mental_health",
          "research_discussion"
        ] &&
        request.resource.data.status == "pending_moderation" &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 10000 &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 300 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;

      allow update: if (
          isCommunityMember() &&
          isOwner(resource.data.authorId) &&
          changedKeysAreOnly(["title", "content", "updatedAt"]) &&
          notChanging("status") &&
          notChanging("authorId") &&
          notChanging("authorName") &&
          notChanging("category") &&
          notChanging("createdAt") &&
          notChanging("replyCount") &&
          notChanging("lastReplyAt")
        ) || isModerator();

      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /forum_comments/{commentId} {
      allow read: if isCommunityMember() &&
        canReadForumPost(resource.data.postId);
      allow create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read, write: if false;
    }

    match /hypotheses/{hypoId} {
      allow read: if false;
      allow create: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.status is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.status is string;
      allow delete: if isAdmin();
    }

    match /hypothesis_comments/{commentId} {
      allow read, write: if false;
    }

    match /research_tasks/{taskId} {
      allow read: if false;
      allow create: if isAdmin() &&
        request.resource.data.type is string &&
        request.resource.data.status is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.type is string &&
        request.resource.data.status is string;
      allow delete: if isAdmin();
    }

    match /agent_events/{eventId} {
      allow read: if false;
      allow create: if isAdmin() &&
        request.resource.data.agentId is string &&
        request.resource.data.eventType is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.agentId is string &&
        request.resource.data.eventType is string;
      allow delete: if isAdmin();
    }

    match /agent_runs/{runId} {
      allow read: if false;
      allow create: if isAdmin() &&
        request.resource.data.agentId is string &&
        request.resource.data.status is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.agentId is string &&
        request.resource.data.status is string;
      allow delete: if isAdmin();
    }

    match /agent_credentials/{agentId} {
      allow read, write: if false;
    }

    match /meta_studies/{studyId} {
      allow read: if resource.data.status == "published";
      allow create: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.status is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdAt <= request.time;
      allow update: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.status is string;
      allow delete: if isAdmin();
    }

    match /agent_submissions/{submissionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /agent_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
